# Reddit API — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=linkedin-meme-bot/1.0

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram — @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # твій особистий chat_id (отримати через @userinfobot)

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=     # urn:li:person:XXXXXXXX

# Subreddits для парсингу (через кому)
SUBREDDITS=ProgrammerHumor,devops,cscareerquestions,ExperiencedDevs

# Скільки мемів парсити за один запуск
REDDIT_FETCH_LIMIT=30

# Скільки постів публікувати в LinkedIn за добу (захист від спаму)
MAX_POSTS_PER_DAY=3
